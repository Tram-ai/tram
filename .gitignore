# API keys and secrets
.env
.env~
.archive
# gemini-cli settings
# We want to keep the .gemini in the root of the repo and ignore any .gemini
# in subdirectories. In our root .gemini we want to allow for version control
# for subcommands.
**/.gemini/
!/.gemini/
.gemini/*
!.gemini/config.yaml
!.gemini/commands/

# Note: .tram-clipboard/ is NOT in gitignore so Gemini can access pasted images

# Dependency directory
node_modules
bower_components
package-lock.json

# Editors
.idea
*.iml
.cursor
.qoder
.claude
CLAUDE.md


.del
.husky
.vscode

